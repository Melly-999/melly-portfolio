---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { projects } from "../../data/portfolio";
---

<BaseLayout
  title="Projects — Mateusz Ozimkiewicz"
  description="A process-to-platform-to-product portfolio: AI Agent Workspace, MellyCore AIOS and the safety-first MellyTrade research dashboard."
>
  <header class="page-intro content-width">
    <p class="section-kicker">Projects</p>
    <h1>A narrative in three layers</h1>
    <p class="page-intro__copy">
      Each project is a step in the same story. Process becomes platform; platform becomes
      product. Read them in order, or jump to what matters.
    </p>
    <div class="story-rail" aria-label="Project sequence">
      <span>01 Process</span><span aria-hidden="true">→</span>
      <span>02 Platform</span><span aria-hidden="true">→</span>
      <span>03 Product</span>
    </div>
  </header>

  <section class="section section--last content-width" aria-label="Portfolio projects">
    <div class="project-list">
      {projects.map((project) => <ProjectCard project={project} detailed />)}
    </div>
  </section>
</BaseLayout>
