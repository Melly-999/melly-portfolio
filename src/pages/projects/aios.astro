---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectBadge from "../../components/ProjectBadge.astro";
---

<BaseLayout
  title="MellyCore AIOS — Mateusz Ozimkiewicz"
  description="MellyCore AIOS: a docs-first AI command center and context architecture prototype."
>
  <section class="section content-width">
    <ProjectBadge variant="platform" label="Platform" />
    <h1 style="margin-top:var(--space-16);font-size:var(--text-h1);">MellyCore AIOS</h1>
    <p class="reading-width" style="margin-top:var(--space-16);color:var(--color-text-secondary);">
      Docs-first AI command center and context architecture prototype. The
      full case study — the Living Context Graph, agent handoff, and the
      cinematic showcase — is coming in a later implementation pass.
    </p>
  </section>
</BaseLayout>
