---
import BaseLayout from "../layouts/BaseLayout.astro";
import CommandCore from "../components/CommandCore.astro";
import ProjectCard from "../components/ProjectCard.astro";
import TerminalProof from "../components/TerminalProof.astro";
import { githubProfile, projects } from "../data/portfolio";

const narrative = [
  {
    step: "01 · Process",
    tone: "process",
    title: "AI Agent Workspace",
    body: "An agent-based workflow across ChatGPT, Claude Code, Codex, Obsidian, GitHub and ClickUp — how the work actually gets done.",
  },
  {
    step: "02 · Platform",
    tone: "platform",
    title: "MellyCore AIOS",
    body: "A context graph and agent-handoff command center that turns process into a reusable platform. Docs-first prototype and static architecture showcase.",
  },
  {
    step: "03 · Product",
    tone: "product",
    title: "MellyTrade",
    body: "A safe, read-only AI trading research dashboard — advisory only, dry-run, no broker execution. A static portfolio case study.",
  },
];
---

<BaseLayout>
  <header class="hero">
    <div class="hero__core" aria-hidden="true"><CommandCore /></div>
    <div class="hero__grid content-width">
      <div>
        <p class="eyebrow">Full-Stack Developer</p>
        <h1 class="hero__title">I build safety-first AI applications and developer tools.</h1>
        <p class="hero__copy">
          I use React, TypeScript, FastAPI and an AI-native development workflow to turn
          documented ideas into clear, testable products.
        </p>
        <p class="hero__stack">React · TypeScript · FastAPI · Astro · AI Tools</p>
        <p class="availability">Available now · Poland / Remote · B2B · Freelance · Contract</p>
        <div class="hero__actions">
          <a href="/projects" class="button button--primary">View Projects <span aria-hidden="true">→</span></a>
          <a href={githubProfile} class="button button--secondary" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
      <div class="hero__terminal"><TerminalProof /></div>
    </div>
  </header>

  <section class="section content-width" aria-label="Process, platform and product story">
    <div class="narrative-grid">
      {
        narrative.map((item) => (
          <article class={`narrative-card narrative-card--${item.tone}`}>
            <p class="narrative-card__meta"><span>{item.step}</span><i aria-hidden="true"></i></p>
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section content-width" aria-labelledby="selected-work-heading">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Selected work</p>
        <h2 id="selected-work-heading">Three layers, one system</h2>
      </div>
      <a href="/projects" class="text-link">All projects <span aria-hidden="true">→</span></a>
    </div>
    <div class="projects-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section content-width" aria-labelledby="showcase-heading">
    <div class="showcase">
      <div class="showcase__grid">
        <div>
          <span class="showcase__label">Cinematic showcase · /projects/aios</span>
          <h2 id="showcase-heading">The AI command center<br />behind the work</h2>
          <p class="showcase__copy">
            MellyCore AIOS is a docs-first prototype of an AI command center — context,
            agents and handoffs mapped into a single graph. A cinematic portfolio route
            tells the platform story end to end.
          </p>
          <a href="/projects/aios" class="button button--primary">Enter the showcase <span aria-hidden="true">→</span></a>
        </div>
        <div class="handoff-card" aria-label="Illustrative static agent handoff flow">
          <p class="handoff-card__heading"><span>Agent handoff</span><span>illustrative flow</span></p>
          <div class="handoff-step handoff-step--info"><span>Claude Code</span><small>plan</small></div>
          <p class="handoff-arrow">↓ context handoff</p>
          <div class="handoff-step handoff-step--brand"><span>Codex</span><small>implement</small></div>
          <p class="handoff-arrow">↓ verify</p>
          <div class="handoff-step handoff-step--safe"><span>Review + ship</span><small>GitHub</small></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--last content-width" aria-labelledby="home-contact-heading">
    <div class="contact-cta">
      <h2 id="home-contact-heading">Open to full-stack roles & freelance</h2>
      <p>Full-stack, AI-tools, B2B, contract and remote. Based in Poland, available worldwide.</p>
      <div class="action-row">
        <a href="/contact" class="button button--primary">Get in touch <span aria-hidden="true">→</span></a>
        <a href="/about" class="button button--secondary">About & skills</a>
      </div>
    </div>
  </section>
</BaseLayout>
