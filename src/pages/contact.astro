---
import BaseLayout from "../layouts/BaseLayout.astro";

const email = "mateusz.ozimkiewicz9@gmail.com";
---

<BaseLayout
  title="Contact — Mateusz Ozimkiewicz"
  description="Get in touch with Mateusz Ozimkiewicz by email or on GitHub."
>
  <section class="section content-width">
    <h1 style="font-size:var(--text-h1);">Contact</h1>
    <p class="reading-width" style="margin-top:var(--space-16);color:var(--color-text-secondary);">
      I'm open to junior full-stack roles (remote or Poland-based). The
      fastest way to reach me is email.
    </p>
    <div class="cluster" style="margin-top:var(--space-24);">
      <a href={`mailto:${email}`} class="button button--primary" style="overflow-wrap:anywhere;">
        {email}
      </a>
      <a
        href="https://github.com/Melly-999"
        class="button button--secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
    </div>
    <p class="mono" style="margin-top:var(--space-24);color:var(--color-text-muted);font-size:var(--text-label);">
      CV link coming soon.
    </p>
  </section>
</BaseLayout>
