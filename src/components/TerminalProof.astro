<div
  class="terminal-proof"
  role="group"
  aria-label="Illustrative static terminal card, not live output. Portfolio status: process AI Agent Workspace, platform MellyCore AIOS, product MellyTrade. Safety check: read only true, dry run true, broker execution blocked, fake metrics prohibited."
>
  <div class="terminal-proof__bar" aria-hidden="true">
    <span class="terminal-dot terminal-dot--danger"></span>
    <span class="terminal-dot terminal-dot--warn"></span>
    <span class="terminal-dot terminal-dot--safe"></span>
    <span class="terminal-proof__path">~/mateusz — portfolio</span>
  </div>
  <div class="terminal-proof__body">
    <p><span class="terminal-prompt">$</span> portfolio.status</p>
    <dl class="terminal-proof__grid terminal-proof__grid--status">
      <dt>process</dt><dd>AI Agent Workspace</dd>
      <dt>platform</dt><dd>MellyCore AIOS</dd>
      <dt>product</dt><dd>MellyTrade</dd>
    </dl>
    <p class="terminal-proof__command"><span class="terminal-prompt">$</span> safety.check</p>
    <dl class="terminal-proof__grid terminal-proof__grid--safety">
      <dt>read_only</dt><dd class="terminal-value--safe">true</dd>
      <dt>dry_run</dt><dd class="terminal-value--safe">true</dd>
      <dt>broker_execution</dt><dd class="terminal-value--blocked">blocked</dd>
      <dt>fake_metrics</dt><dd class="terminal-value--blocked">prohibited</dd>
    </dl>
    <p class="terminal-proof__cursor" aria-hidden="true">
      <span class="terminal-prompt">$</span> <span></span>
    </p>
  </div>
</div>
