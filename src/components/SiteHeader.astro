---
import MobileMenu from "./MobileMenu.astro";
import { githubProfile } from "../data/portfolio";

const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
const githubItem = { href: githubProfile, label: "GitHub ↗", external: true };

function isCurrent(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<div class="site-chrome" data-site-chrome>
  <header class="site-header content-width">
    <a href="/" class="site-identity" aria-label="Mateusz Ozimkiewicz, home">
      <span class="site-identity__mark" aria-hidden="true">MO</span>
      <span class="site-identity__copy">
        <span class="site-identity__name">
          <span class="site-identity__full-name">Mateusz Ozimkiewicz</span>
          <span class="site-identity__short-name">Mateusz</span>
        </span>
        <span class="site-identity__role">Full-Stack Developer</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a href={item.href} class="site-nav__link" aria-current={isCurrent(item.href) ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
      <a href={githubItem.href} class="site-nav__link" target="_blank" rel="noopener noreferrer">
        {githubItem.label}
      </a>
    </nav>

    <button
      id="menu-toggle"
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span>Menu</span>
      <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 5h14M3 10h14M3 15h14" /></svg>
    </button>
  </header>

  <MobileMenu items={[...navItems, githubItem]} currentPath={currentPath} />
  <noscript>
    <nav class="noscript-nav" aria-label="Navigation without JavaScript">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </noscript>
</div>

<script>
  const chrome = document.querySelector<HTMLElement>("[data-site-chrome]");
  const toggle = chrome?.querySelector<HTMLButtonElement>("#menu-toggle");
  const menu = chrome?.querySelector<HTMLElement>("#mobile-menu");
  const desktop = window.matchMedia("(min-width: 760px)");

  if (toggle && menu) {
    const closeMenu = (returnFocus = false) => {
      menu.hidden = true;
      toggle.setAttribute("aria-expanded", "false");
      if (returnFocus) toggle.focus();
    };

    const openMenu = () => {
      menu.hidden = false;
      toggle.setAttribute("aria-expanded", "true");
      requestAnimationFrame(() => menu.querySelector<HTMLAnchorElement>("a")?.focus());
    };

    toggle.addEventListener("click", () => {
      toggle.getAttribute("aria-expanded") === "true" ? closeMenu() : openMenu();
    });

    menu.addEventListener("click", (event) => {
      if ((event.target as HTMLElement).closest("a")) closeMenu();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        closeMenu(true);
      }
    });

    desktop.addEventListener("change", (event) => {
      if (event.matches) closeMenu();
    });
  }
</script>
