---
import ProjectBadge from "./ProjectBadge.astro";
import type { ProjectTone } from "../data/portfolio";

interface Props {
  number: string;
  layer: string;
  tone: ProjectTone;
  title: string;
  tagline: string;
  description: string;
}

const { number, layer, tone, title, tagline, description } = Astro.props;
---

<header class="case-hero content-width content-width--case">
  <nav class="case-hero__breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a class="case-hero__back" href="/projects">Projects</a></li>
      <li aria-hidden="true">/</li>
      <li><span class="case-hero__crumb" aria-current="page">{title} · {layer}</span></li>
    </ol>
  </nav>
  <div class="case-hero__layer"><ProjectBadge variant={tone} label={`${number} · ${layer} layer`} /></div>
  <h1>{title}</h1>
  <p class="case-hero__tagline">{tagline}</p>
  <p class="case-hero__description">{description}</p>
  <slot name="status" />
</header>
