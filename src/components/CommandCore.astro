---
interface Props {
  class?: string;
}

const className = Astro.props.class ?? "";
---

<svg
  class={`command-core ${className}`}
  viewBox="0 0 620 560"
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <radialGradient id="core-fill" cx="50%" cy="44%" r="60%">
      <stop offset="0" stop-color="#f7933c" stop-opacity="0.36" />
      <stop offset="0.48" stop-color="#131a2b" stop-opacity="0.92" />
      <stop offset="1" stop-color="#06080f" stop-opacity="0" />
    </radialGradient>
    <filter id="core-glow" x="-80%" y="-80%" width="260%" height="260%">
      <feGaussianBlur stdDeviation="9" />
    </filter>
  </defs>
  <ellipse class="command-core__halo" cx="326" cy="274" rx="205" ry="187" />
  <g class="command-core__orbit command-core__orbit--outer">
    <ellipse cx="326" cy="274" rx="235" ry="198" />
    <circle cx="109" cy="198" r="5" />
    <circle cx="514" cy="393" r="4" />
  </g>
  <g class="command-core__orbit command-core__orbit--middle">
    <ellipse cx="326" cy="274" rx="176" ry="145" />
    <circle cx="448" cy="169" r="5" />
    <circle cx="183" cy="358" r="4" />
  </g>
  <g class="command-core__orbit command-core__orbit--inner">
    <ellipse cx="326" cy="274" rx="122" ry="96" />
    <circle cx="242" cy="205" r="4" />
    <circle cx="411" cy="339" r="4" />
  </g>
  <circle class="command-core__glow" cx="326" cy="274" r="96" />
  <circle class="command-core__center" cx="326" cy="274" r="66" />
  <path class="command-core__mark" d="M292 275h68M326 241v68" />
</svg>
