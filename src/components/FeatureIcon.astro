---
interface Props {
  name: "context" | "handoff" | "command" | "safety" | "clarity" | "human";
}

const { name } = Astro.props;
---

<span class={`feature-icon feature-icon--${name}`} aria-hidden="true">
  {
    name === "context" && <svg viewBox="0 0 24 24"><circle cx="6" cy="7" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="16" cy="18" r="2"/><path d="m8 7 8-1M7 9l8 7M17 8l-1 8"/></svg>
  }
  {
    name === "handoff" && <svg viewBox="0 0 24 24"><path d="M4 7h11m-3-3 3 3-3 3M20 17H9m3-3-3 3 3 3"/></svg>
  }
  {
    name === "command" && <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="3"/><path d="m7 9 3 3-3 3m5 0h5"/></svg>
  }
  {
    name === "safety" && <svg viewBox="0 0 24 24"><path d="M12 3 20 6v5c0 5-3.4 8.5-8 10-4.6-1.5-8-5-8-10V6l8-3Z"/><path d="m8.5 12 2.2 2.2 4.8-5"/></svg>
  }
  {
    name === "clarity" && <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8"/><path d="m9 15 6-6M9 9h.01M15 15h.01"/></svg>
  }
  {
    name === "human" && <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3"/><path d="M5 20c.8-4.2 3.1-6 7-6s6.2 1.8 7 6"/></svg>
  }
</span>
